<Window x:Class="DBKeeper.App.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="DB Keeper" Height="460" Width="420"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" ResizeMode="NoResize"
        AllowsTransparency="True" Background="Transparent"
        ShowInTaskbar="True"
        Icon="pack://application:,,,/app.ico">

    <Border CornerRadius="12"
            Background="{DynamicResource ApplicationBackgroundBrush}"
            TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid>
            <!-- 关闭按钮 -->
            <Button x:Name="btnClose" Content="✕" 
                    HorizontalAlignment="Right" VerticalAlignment="Top"
                    Margin="0,12,12,0" Width="32" Height="32"
                    Background="Transparent" BorderThickness="0"
                    FontSize="14" Click="BtnClose_Click" />

            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Width="280">
                <!-- Logo Banner -->
                <Image Source="/Assets/logo_banner.png" Height="120"
                       HorizontalAlignment="Center" Margin="0,0,0,28"
                       RenderOptions.BitmapScalingMode="HighQuality" />

                <!-- 密码输入 -->
                <TextBlock Text="请输入启动密码" FontSize="14" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                <ui:PasswordBox x:Name="passwordBox" PlaceholderText="输入密码..."
                                Margin="0,0,0,8" KeyDown="PasswordBox_KeyDown" />

                <!-- 错误提示 -->
                <TextBlock x:Name="errorText" Foreground="{DynamicResource ErrorBrush}" FontSize="12"
                           Margin="0,0,0,12" TextWrapping="Wrap"
                           Visibility="Collapsed" />

                <!-- 进入按钮 -->
                <ui:Button x:Name="btnLogin" Content="进入" Appearance="Primary"
                           HorizontalAlignment="Stretch" Height="36"
                           Click="BtnLogin_Click" />

                <!-- 提示 -->
                <TextBlock Text="连续 3 次输错将退出程序" FontSize="11"
                           HorizontalAlignment="Center" Margin="0,16,0,0"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
