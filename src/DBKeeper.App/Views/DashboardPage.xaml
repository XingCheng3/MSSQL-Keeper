<Page x:Class="DBKeeper.App.Views.DashboardPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="概览" Loaded="Page_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto"
                  PreviewMouseWheel="ScrollViewer_PreviewMouseWheel"
                  TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <StackPanel Margin="24">
            <!-- 标题 -->
            <DockPanel Margin="0,0,0,16">
                <TextBlock Text="概览" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
                <ui:Button Content="刷新" DockPanel.Dock="Right" HorizontalAlignment="Right"
                           Icon="{ui:SymbolIcon ArrowSync24}" Click="Refresh_Click" />
            </DockPanel>

            <!-- 统计卡片行 -->
            <UniformGrid Rows="1" Columns="4" Margin="0,0,0,20">
                <!-- 活跃任务 -->
                <Border Margin="0,0,12,0" Padding="20,16" CornerRadius="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <DockPanel>
                        <ui:SymbolIcon Symbol="Timer24" FontSize="28" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                       DockPanel.Dock="Left" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="{Binding ActiveTaskCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource SystemAccentColorPrimaryBrush}" />
                            <TextBlock Text="活跃任务" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 今日执行 -->
                <Border Margin="0,0,12,0" Padding="20,16" CornerRadius="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <DockPanel>
                        <ui:SymbolIcon Symbol="CheckmarkCircle24" FontSize="28" VerticalAlignment="Center"
                                       Foreground="{DynamicResource SuccessBrush}"
                                       DockPanel.Dock="Left" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="{Binding TodayExecutionCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource SuccessBrush}" />
                            <TextBlock Text="今日执行" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 失败数 -->
                <Border Margin="0,0,12,0" Padding="20,16" CornerRadius="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <DockPanel>
                        <ui:SymbolIcon Symbol="ErrorCircle24" FontSize="28" VerticalAlignment="Center"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       DockPanel.Dock="Left" Margin="0,0,12,0" />
                        <StackPanel>
                            <TextBlock Text="{Binding TodayFailedCount}" FontSize="28" FontWeight="Bold"
                                       Foreground="{DynamicResource ErrorBrush}" />
                            <TextBlock Text="失败任务" FontSize="12"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        </StackPanel>
                    </DockPanel>
                </Border>

                <!-- 磁盘空间 - 进度条+结构化 -->
                <Border Padding="20,16" CornerRadius="8"
                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                    <StackPanel>
                        <DockPanel Margin="0,0,0,6">
                            <ui:SymbolIcon Symbol="HardDrive24" FontSize="18" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SystemAccentColorPrimaryBrush}"
                                           Margin="0,0,8,0" />
                            <TextBlock Text="{Binding DiskDrive}" FontSize="14" FontWeight="SemiBold"
                                       VerticalAlignment="Center" />
                            <TextBlock Text="备份盘" FontSize="12" DockPanel.Dock="Right"
                                       HorizontalAlignment="Right" VerticalAlignment="Center"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </DockPanel>
                        <ProgressBar Value="{Binding DiskUsedPercent}" Maximum="100" Height="6"
                                     Margin="0,0,0,6" />
                        <DockPanel>
                            <TextBlock FontSize="11" Foreground="{DynamicResource TextFillColorSecondaryBrush}">
                                <Run Text="可用 " /><Run Text="{Binding DiskFreeGb}" /><Run Text=" GB" />
                            </TextBlock>
                            <TextBlock FontSize="11" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}">
                                <Run Text="共 " /><Run Text="{Binding DiskTotalGb}" /><Run Text=" GB" />
                            </TextBlock>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- 两列布局 -->
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="360" />
                </Grid.ColumnDefinitions>

                <!-- 左列 - 最近日志 -->
                <StackPanel Grid.Column="0" Margin="0,0,16,0">
                    <TextBlock Text="最近执行日志" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <DataGrid x:Name="recentGrid" AutoGenerateColumns="False" IsReadOnly="True"
                              MaxHeight="400" HeadersVisibility="Column" GridLinesVisibility="None"
                              Background="Transparent" BorderThickness="0"
                              Foreground="{DynamicResource TextFillColorPrimaryBrush}"
                              RowBackground="Transparent"
                              AlternatingRowBackground="{DynamicResource CardBackgroundFillColorDefaultBrush}">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="时间" Binding="{Binding StartedAt, Converter={StaticResource IsoDateTime}, ConverterParameter=MM-dd HH:mm}" Width="110" />
                            <DataGridTextColumn Header="任务名" Binding="{Binding TaskName}" Width="*" />
                            <DataGridTextColumn Header="类型" Binding="{Binding TaskType}" Width="130" />
                            <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="80" />
                            <DataGridTextColumn Header="耗时" Binding="{Binding DurationMs, StringFormat='{}{0}ms'}" Width="100" />
                        </DataGrid.Columns>
                    </DataGrid>
                </StackPanel>

                <!-- 右列 -->
                <StackPanel Grid.Column="1">
                    <!-- 即将执行 -->
                    <TextBlock Text="即将执行的任务" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8" />
                    <ItemsControl x:Name="upcomingList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,0,0,6" CornerRadius="6"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <DockPanel>
                                        <ui:SymbolIcon Symbol="Clock24" FontSize="16" Margin="0,0,8,0"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="{Binding Name}" FontWeight="Medium" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   VerticalAlignment="Center"
                                                   Text="{Binding NextRunAt, Converter={StaticResource IsoDateTime}, ConverterParameter=MM-dd HH:mm}"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" FontSize="12" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 连接状态 -->
                    <TextBlock Text="连接状态" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,8" />
                    <ItemsControl x:Name="connectionStatusList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Padding="12,10" Margin="0,0,0,6" CornerRadius="6"
                                        Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                        BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                                    <DockPanel>
                                        <Ellipse Width="8" Height="8" Margin="0,0,8,0" VerticalAlignment="Center"
                                                 Fill="{DynamicResource NeutralBrush}" />
                                        <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                        <TextBlock DockPanel.Dock="Right" HorizontalAlignment="Right"
                                                   Text="{Binding Host}" FontSize="12" VerticalAlignment="Center"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- 备份统计 -->
                    <TextBlock Text="备份统计" FontSize="16" FontWeight="SemiBold" Margin="0,20,0,8" />
                    <Border Padding="16" CornerRadius="8"
                            Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                            BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                        <StackPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="总备份数" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding TotalBackupCount}" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" FontWeight="SemiBold" />
                            </DockPanel>
                            <DockPanel Margin="0,0,0,6">
                                <TextBlock Text="总占用空间" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding TotalBackupSize}" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" FontWeight="SemiBold" />
                            </DockPanel>
                            <DockPanel>
                                <TextBlock Text="最近备份" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                <TextBlock Text="{Binding LastBackupTime}" DockPanel.Dock="Right"
                                           HorizontalAlignment="Right" FontWeight="SemiBold" />
                            </DockPanel>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </StackPanel>
    </ScrollViewer>
</Page>
