<Page x:Class="DBKeeper.App.Views.SettingsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="系统设置" Loaded="Page_Loaded">

    <!-- 用 Grid 填满整个内容区，ScrollViewer 在 Grid 内获得正确的高度约束 -->
    <Grid TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <ScrollViewer x:Name="settingsScroller"
                      Style="{StaticResource DbkPageScrollViewerStyle}"
                      PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
            <StackPanel Margin="24,24,24,40">
                <TextBlock Text="系统设置" Style="{StaticResource DbkPageTitleTextStyle}" Margin="0,0,0,20" />

                <!-- ────── 常规 ────── -->
                <TextBlock Text="常规" Style="{StaticResource DbkSettingsGroupTitleTextStyle}" Margin="0,0,0,10" />

                <Border Style="{StaticResource DbkCardBorderStyle}">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="关闭窗口最小化到托盘" FontSize="13" />
                            <TextBlock Text="点击关闭按钮时隐藏窗口而非退出" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <ToggleButton x:Name="toggleTray" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                      VerticalAlignment="Center" Click="Setting_Changed" />
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource DbkCardBorderStyle}">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="开机自启" FontSize="13" />
                            <TextBlock Text="Windows 登录后自动启动 DB Keeper" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <ToggleButton x:Name="toggleAutoStart" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                      VerticalAlignment="Center" Click="AutoStart_Changed" />
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource DbkCardBorderStyle}">
                    <DockPanel>
                        <TextBlock Text="日志保留天数" FontSize="13" VerticalAlignment="Center" />
                        <ComboBox x:Name="cmbLogRetention" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                  Width="100" SelectionChanged="LogRetention_Changed">
                            <ComboBoxItem Content="30 天" Tag="30" />
                            <ComboBoxItem Content="60 天" Tag="60" />
                            <ComboBoxItem Content="90 天" Tag="90" />
                            <ComboBoxItem Content="180 天" Tag="180" />
                        </ComboBox>
                    </DockPanel>
                </Border>

                <!-- ────── 备份 ────── -->
                <TextBlock Text="备份" Style="{StaticResource DbkSettingsGroupTitleTextStyle}" />

                <Border Style="{StaticResource DbkCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="默认备份目录" FontSize="13" Margin="0,0,0,4" />
                        <TextBlock Text="新建备份任务时自动填充的目录路径" FontSize="11" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <DockPanel>
                            <ui:Button Content="浏览" DockPanel.Dock="Right" Margin="8,0,0,0"
                                       Click="BrowseBackupDir_Click" />
                            <ui:TextBox x:Name="txtDefaultBackupDir" PlaceholderText="D:\Backup" />
                        </DockPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DbkCardBorderStyle}">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="备份文件扫描间隔" FontSize="13" />
                            <TextBlock Text="定期扫描备份目录，检测磁盘文件是否缺失" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <ComboBox x:Name="cmbScanInterval" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                  Width="100" SelectionChanged="ScanInterval_Changed">
                            <ComboBoxItem Content="10 分钟" Tag="10" />
                            <ComboBoxItem Content="15 分钟" Tag="15" />
                            <ComboBoxItem Content="30 分钟" Tag="30" />
                            <ComboBoxItem Content="60 分钟" Tag="60" />
                        </ComboBox>
                    </DockPanel>
                </Border>

                <!-- ────── 调度引擎 ────── -->
                <TextBlock Text="调度引擎" Style="{StaticResource DbkSettingsGroupTitleTextStyle}" />

                <Border Style="{StaticResource DbkCardBorderStyle}">
                    <DockPanel>
                        <TextBlock Text="任务并发上限" FontSize="13" VerticalAlignment="Center" />
                        <ComboBox x:Name="cmbConcurrency" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                  Width="80" SelectionChanged="Concurrency_Changed">
                            <ComboBoxItem Content="1" Tag="1" />
                            <ComboBoxItem Content="2" Tag="2" />
                            <ComboBoxItem Content="3" Tag="3" />
                            <ComboBoxItem Content="5" Tag="5" />
                        </ComboBox>
                    </DockPanel>
                </Border>

                <!-- ────── 数据管理 ────── -->
                <TextBlock Text="数据管理" Style="{StaticResource DbkSettingsGroupTitleTextStyle}" />

                <Border Style="{StaticResource DbkCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="配置导入导出" FontSize="13" Margin="0,0,0,4" />
                        <TextBlock Text="导出连接、任务和设置为 JSON 文件（密码脱敏），可导入到其他实例" FontSize="11" Margin="0,0,0,8"
                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        <StackPanel Orientation="Horizontal">
                            <ui:Button Content="导出配置" Icon="{ui:SymbolIcon Save24}" Margin="0,0,8,0"
                                       Click="ExportConfig_Click" />
                            <ui:Button Content="导入配置" Icon="{ui:SymbolIcon ArrowImport24}"
                                       Click="ImportConfig_Click" />
                        </StackPanel>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource DbkCardBorderStyle}">
                    <DockPanel>
                        <TextBlock Text="清空所有执行日志" FontSize="13" VerticalAlignment="Center" />
                        <ui:Button Content="清空" Appearance="Danger" DockPanel.Dock="Right"
                                   HorizontalAlignment="Right" Click="ClearLogs_Click" />
                    </DockPanel>
                </Border>

                <Border Style="{StaticResource DbkCardBorderStyle}">
                    <DockPanel>
                        <StackPanel>
                            <TextBlock Text="本地数据库 (SQLite)" FontSize="13" />
                            <TextBlock x:Name="txtDbPath" FontSize="11"
                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                        </StackPanel>
                        <ui:Button Content="打开目录" DockPanel.Dock="Right" HorizontalAlignment="Right"
                                   VerticalAlignment="Center" Click="OpenDbFolder_Click" />
                    </DockPanel>
                </Border>

                <!-- ────── 关于 ────── -->
                <TextBlock Text="关于" Style="{StaticResource DbkSettingsGroupTitleTextStyle}" />
                <Border Style="{StaticResource DbkCardBorderStyle}" Margin="0,0,0,20">
                    <TextBlock Text="DB Keeper v1.0.0  ·  .NET 8  ·  WPF-UI" FontSize="12"
                               Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
