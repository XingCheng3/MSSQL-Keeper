<Page x:Class="DBKeeper.App.Views.TaskListPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="定时任务" Loaded="Page_Loaded">

    <Grid Style="{StaticResource DbkPageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <DockPanel Grid.Row="0" Style="{StaticResource DbkPageTitleBarStyle}">
            <TextBlock Text="定时任务" Style="{StaticResource DbkPageTitleTextStyle}" />
            <ui:Button Content="+ 新建任务" Appearance="Primary" DockPanel.Dock="Right"
                       HorizontalAlignment="Right" Click="NewTask_Click" />
        </DockPanel>

        <!-- 过滤 -->
        <StackPanel Grid.Row="1" Style="{StaticResource DbkFilterBarStyle}">
            <ComboBox x:Name="cmbType" Width="120" Margin="0,0,8,0" SelectionChanged="Filter_Changed"
                      MaxDropDownHeight="260" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ComboBoxItem Content="全部类型" IsSelected="True" />
                <ComboBoxItem Content="备份" Tag="BACKUP" />
                <ComboBoxItem Content="存储过程" Tag="PROCEDURE" />
                <ComboBoxItem Content="自定义SQL" Tag="CUSTOM_SQL" />
                <ComboBoxItem Content="备份清理" Tag="BACKUP_CLEANUP" />
            </ComboBox>
            <ComboBox x:Name="cmbStatus" Width="120" Margin="0,0,8,0" SelectionChanged="Filter_Changed"
                      MaxDropDownHeight="220" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ComboBoxItem Content="全部状态" IsSelected="True" />
                <ComboBoxItem Content="执行中" Tag="RUNNING" />
                <ComboBoxItem Content="成功" Tag="SUCCESS" />
                <ComboBoxItem Content="警告" Tag="WARNING" />
                <ComboBoxItem Content="失败" Tag="FAILED" />
                <ComboBoxItem Content="已取消" Tag="CANCELLED" />
            </ComboBox>
            <ui:TextBox x:Name="txtSearch" PlaceholderText="搜索任务..." Width="200"
                        TextChanged="Search_Changed" />
        </StackPanel>

        <!-- 空状态 -->
        <StackPanel x:Name="emptyState" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <ui:SymbolIcon Symbol="CalendarEmpty24" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="暂无定时任务" FontSize="16" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <TextBlock Text="创建第一个任务，开始自动化管理数据库维护" FontSize="13" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,16" />
            <ui:Button Content="+ 新建任务" Appearance="Primary" HorizontalAlignment="Center"
                       Click="NewTask_Click" />
        </StackPanel>

        <!-- 任务列表 -->
        <DataGrid x:Name="taskGrid" Grid.Row="2" Style="{StaticResource DbkDataGridStyle}"
                  CanUserSortColumns="True" SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTextColumn Header="名称" Binding="{Binding Model.Name}" Width="*" />
                <DataGridTextColumn Header="类型" Binding="{Binding TypeDisplay}" Width="80" />
                <DataGridTextColumn Header="连接" Binding="{Binding ConnectionName}" Width="100" />
                <DataGridTextColumn Header="周期" Binding="{Binding ScheduleDisplay}" Width="140" />
                <DataGridTextColumn Header="上次执行" Binding="{Binding StatusDisplay}" Width="90" />
                <DataGridTemplateColumn Header="启用" Width="60">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <ToggleButton IsChecked="{Binding IsEnabled, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                          Click="ToggleEnabled_Click" Tag="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTemplateColumn Header="操作" Width="180">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button ToolTip="立即执行" Margin="0,0,4,0"
                                           Icon="{ui:SymbolIcon Play24}"
                                           IsEnabled="{Binding IsRunning, Converter={StaticResource InvertBool}}"
                                           Tag="{Binding}" Click="ExecuteNow_Click" />
                                <ui:Button ToolTip="取消执行" Margin="0,0,4,0"
                                           Appearance="Danger"
                                           Icon="{ui:SymbolIcon Dismiss24}"
                                           Visibility="{Binding IsRunning, Converter={StaticResource BoolToVisibility}}"
                                           IsEnabled="{Binding IsCancelling, Converter={StaticResource InvertBool}}"
                                           Tag="{Binding}" Click="CancelTask_Click" />
                                <ui:Button ToolTip="编辑" Margin="0,0,4,0"
                                           Icon="{ui:SymbolIcon Edit24}"
                                           Tag="{Binding}" Click="EditTask_Click" />
                                <ui:Button ToolTip="删除" Appearance="Danger"
                                           Icon="{ui:SymbolIcon Delete24}"
                                           Tag="{Binding}" Click="DeleteTask_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
