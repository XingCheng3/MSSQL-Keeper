<Page x:Class="DBKeeper.App.Views.ConnectionsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      xmlns:vm="clr-namespace:DBKeeper.App.ViewModels"
      Title="连接管理" Loaded="Page_Loaded">

    <Grid Margin="24" TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题栏 -->
        <DockPanel Grid.Row="0" Margin="0,0,0,16">
            <TextBlock Text="连接管理" FontSize="22" FontWeight="SemiBold" VerticalAlignment="Center" />
            <ui:Button Content="+ 新建连接" Appearance="Primary" DockPanel.Dock="Right"
                       HorizontalAlignment="Right" Click="NewConnection_Click" />
        </DockPanel>

        <!-- 空状态 -->
        <StackPanel x:Name="emptyState" Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <ui:SymbolIcon Symbol="PlugDisconnected24" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="暂无数据库连接" FontSize="16" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" Margin="0,0,0,4" />
            <TextBlock Text="添加第一个 SQL Server 连接" FontSize="13" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" Margin="0,0,0,16" />
            <ui:Button Content="+ 新建连接" Appearance="Primary" HorizontalAlignment="Center"
                       Click="NewConnection_Click" />
        </StackPanel>

        <!-- 连接卡片列表 -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                      PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
            <ItemsControl x:Name="cardList">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel />
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
                <ItemsControl.ItemTemplate>
                    <DataTemplate>
                        <Border Width="340" Margin="0,0,12,12" Padding="20" CornerRadius="8"
                                Background="{DynamicResource CardBackgroundFillColorDefaultBrush}"
                                BorderBrush="{DynamicResource CardStrokeColorDefaultBrush}" BorderThickness="1">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- 标题行 -->
                                <DockPanel Grid.Row="0" Margin="0,0,0,10">
                                    <Ellipse Width="10" Height="10" Margin="0,0,10,0" VerticalAlignment="Center">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource NeutralBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsOnline}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="{Binding Model.Name}" FontSize="16" FontWeight="SemiBold"
                                               VerticalAlignment="Center" />
                                    <Border DockPanel.Dock="Right" HorizontalAlignment="Right"
                                            Background="{DynamicResource WarningBrush}" CornerRadius="3"
                                            Padding="6,2" VerticalAlignment="Center"
                                            Visibility="{Binding IsDefault, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="默认" FontSize="11" Foreground="White" />
                                    </Border>
                                </DockPanel>

                                <!-- 服务器信息 -->
                                <StackPanel Grid.Row="1" Margin="0,0,0,10">
                                    <DockPanel Margin="0,0,0,4">
                                        <ui:SymbolIcon Symbol="Server24" FontSize="14" Margin="0,0,6,0"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="{Binding Model.Host}" FontSize="13"
                                                   Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                                    </DockPanel>
                                    <DockPanel Margin="0,0,0,4">
                                        <ui:SymbolIcon Symbol="Person24" FontSize="14" Margin="0,0,6,0"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <TextBlock Text="{Binding Model.Username}" FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                    </DockPanel>
                                    <DockPanel>
                                        <ui:SymbolIcon Symbol="Database24" FontSize="14" Margin="0,0,6,0"
                                                       Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
                                        <TextBlock FontSize="12"
                                                   Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                                   Text="{Binding Model.DefaultDb, TargetNullValue='master'}" />
                                    </DockPanel>
                                </StackPanel>

                                <!-- 状态文字 -->
                                <TextBlock Grid.Row="2" Text="{Binding StatusText}" FontSize="11" Margin="0,0,0,12"
                                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                                           Visibility="{Binding StatusText, Converter={StaticResource NullToCollapsed}}" />

                                <!-- 操作按钮 -->
                                <StackPanel Grid.Row="3" Orientation="Horizontal">
                                    <ui:Button Content="测试" Appearance="Secondary" Margin="0,0,8,0"
                                               IsEnabled="{Binding IsTesting, Converter={StaticResource InvertBool}}"
                                               Tag="{Binding}" Click="TestConnection_Click" />
                                    <ui:Button Content="编辑" Margin="0,0,8,0"
                                               Tag="{Binding}" Click="EditConnection_Click" />
                                    <ui:Button Content="删除" Appearance="Danger"
                                               Tag="{Binding}" Click="DeleteConnection_Click" />
                                </StackPanel>
                            </Grid>
                        </Border>
                    </DataTemplate>
                </ItemsControl.ItemTemplate>
            </ItemsControl>
        </ScrollViewer>
    </Grid>
</Page>
