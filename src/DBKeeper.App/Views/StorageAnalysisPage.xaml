<Page x:Class="DBKeeper.App.Views.StorageAnalysisPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="空间分析" Loaded="Page_Loaded">

    <Grid Style="{StaticResource DbkPageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <DockPanel Grid.Row="0" Style="{StaticResource DbkPageTitleBarStyle}">
            <TextBlock Text="空间分析" Style="{StaticResource DbkPageTitleTextStyle}" />
        </DockPanel>

        <StackPanel Grid.Row="1" Style="{StaticResource DbkFilterBarStyle}">
            <ComboBox Width="180" Margin="0,0,8,0"
                      ItemsSource="{Binding Connections}"
                      DisplayMemberPath="Name"
                      SelectedItem="{Binding SelectedConnection, Mode=TwoWay}"
                      MaxDropDownHeight="260"
                      ScrollViewer.VerticalScrollBarVisibility="Auto" />
            <ComboBox Width="220" Margin="0,0,8,0"
                      ItemsSource="{Binding Databases}"
                      SelectedItem="{Binding SelectedDatabase, Mode=TwoWay}"
                      MaxDropDownHeight="260"
                      ScrollViewer.VerticalScrollBarVisibility="Auto" />
            <ui:Button Content="分析" Appearance="Primary" Margin="0,0,8,0"
                       Icon="{ui:SymbolIcon Search24}"
                       IsEnabled="{Binding IsAnalyzing, Converter={StaticResource InvertBool}}"
                       Command="{Binding AnalyzeCommand}" />
            <ui:Button Content="取消" Margin="0,0,8,0"
                       Icon="{ui:SymbolIcon Dismiss24}"
                       Visibility="{Binding IsAnalyzing, Converter={StaticResource BoolToVisibility}}"
                       Command="{Binding CancelAnalyzeCommand}" />
            <TextBlock Text="{Binding StatusText}" VerticalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <StackPanel Grid.Row="2" Margin="0,0,0,12">
            <TextBlock Text="{Binding ErrorMessage}" Margin="0,0,0,8"
                       Foreground="{DynamicResource SystemFillColorCriticalBrush}"
                       Visibility="{Binding ErrorMessage, Converter={StaticResource NullToCollapsed}}" />

            <UniformGrid Columns="6">
                <Border Style="{StaticResource DbkSummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="总大小" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Overview.TotalMb, StringFormat={}{0:N1} MB}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DbkSummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="数据文件" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Overview.DataMb, StringFormat={}{0:N1} MB}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DbkSummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="日志文件" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Overview.LogMb, StringFormat={}{0:N1} MB}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DbkSummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="未使用" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Overview.UnusedMb, StringFormat={}{0:N1} MB}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DbkSummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="表数量" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Overview.TableCount}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
                <Border Style="{StaticResource DbkSummaryCardBorderStyle}">
                    <StackPanel>
                        <TextBlock Text="索引数量" Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
                        <TextBlock Text="{Binding Overview.IndexCount}" FontSize="20" FontWeight="SemiBold" />
                    </StackPanel>
                </Border>
            </UniformGrid>
        </StackPanel>

        <TabControl Grid.Row="3">
            <TabItem Header="表空间排行">
                <Grid Margin="0,12,0,0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Row="0" Style="{StaticResource DbkFilterBarStyle}">
                        <ui:TextBox Width="220" Margin="0,0,8,0"
                                    PlaceholderText="搜索 Schema / 表 / 索引..."
                                    Text="{Binding SearchText, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" />
                        <ComboBox Width="150"
                                  SelectedValue="{Binding SortMode, Mode=TwoWay}"
                                  SelectedValuePath="Tag">
                            <ComboBoxItem Content="按总大小排序" Tag="TOTAL" IsSelected="True" />
                            <ComboBoxItem Content="按数据大小排序" Tag="DATA" />
                            <ComboBoxItem Content="按索引大小排序" Tag="INDEX" />
                        </ComboBox>
                    </StackPanel>

                    <DataGrid Grid.Row="1" Style="{StaticResource DbkDataGridStyle}"
                              ItemsSource="{Binding Tables}"
                              CanUserSortColumns="True">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Schema" Binding="{Binding SchemaName}" Width="120" />
                            <DataGridTextColumn Header="表名" Binding="{Binding TableName}" Width="*" />
                            <DataGridTextColumn Header="行数" Binding="{Binding RowCount, StringFormat={}{0:N0}}" Width="100" />
                            <DataGridTextColumn Header="总大小" Binding="{Binding TotalMb, StringFormat={}{0:N1} MB}" Width="100" />
                            <DataGridTextColumn Header="数据" Binding="{Binding DataMb, StringFormat={}{0:N1} MB}" Width="100" />
                            <DataGridTextColumn Header="索引" Binding="{Binding IndexMb, StringFormat={}{0:N1} MB}" Width="100" />
                            <DataGridTextColumn Header="未使用" Binding="{Binding UnusedMb, StringFormat={}{0:N1} MB}" Width="100" />
                            <DataGridTextColumn Header="占比" Binding="{Binding PercentOfDatabase, StringFormat={}{0:N2}%}" Width="80" />
                        </DataGrid.Columns>
                    </DataGrid>
                </Grid>
            </TabItem>

            <TabItem Header="文件组成">
                <DataGrid Margin="0,12,0,0" Style="{StaticResource DbkDataGridStyle}"
                          ItemsSource="{Binding Files}"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="160" />
                        <DataGridTextColumn Header="类型" Binding="{Binding FileType}" Width="80" />
                        <DataGridTextColumn Header="文件组" Binding="{Binding FileGroup}" Width="120" />
                        <DataGridTextColumn Header="当前大小" Binding="{Binding SizeMb, StringFormat={}{0:N1} MB}" Width="110" />
                        <DataGridTextColumn Header="已用" Binding="{Binding UsedMb, StringFormat={}{0:N1} MB}" Width="110" />
                        <DataGridTextColumn Header="可用" Binding="{Binding FreeMb, StringFormat={}{0:N1} MB}" Width="110" />
                        <DataGridTextColumn Header="增长" Binding="{Binding Growth}" Width="100" />
                        <DataGridTextColumn Header="物理路径" Binding="{Binding PhysicalName}" Width="*" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>

            <TabItem Header="索引空间排行">
                <DataGrid Margin="0,12,0,0" Style="{StaticResource DbkDataGridStyle}"
                          ItemsSource="{Binding Indexes}"
                          CanUserSortColumns="True">
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Schema" Binding="{Binding SchemaName}" Width="120" />
                        <DataGridTextColumn Header="表名" Binding="{Binding TableName}" Width="*" />
                        <DataGridTextColumn Header="索引名" Binding="{Binding IndexName}" Width="220" />
                        <DataGridTextColumn Header="类型" Binding="{Binding IndexType}" Width="150" />
                        <DataGridTextColumn Header="行数" Binding="{Binding RowCount, StringFormat={}{0:N0}}" Width="100" />
                        <DataGridTextColumn Header="大小" Binding="{Binding SizeMb, StringFormat={}{0:N1} MB}" Width="110" />
                    </DataGrid.Columns>
                </DataGrid>
            </TabItem>
        </TabControl>
    </Grid>
</Page>
