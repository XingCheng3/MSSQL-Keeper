<Page x:Class="DBKeeper.App.Views.BackupFilesPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="备份管理" Loaded="Page_Loaded">

    <Grid Style="{StaticResource DbkPageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <DockPanel Grid.Row="0" Style="{StaticResource DbkPageTitleBarStyle}">
            <TextBlock Text="备份管理" Style="{StaticResource DbkPageTitleTextStyle}" />
            <ui:Button Content="刷新扫描" DockPanel.Dock="Right" HorizontalAlignment="Right"
                       Icon="{ui:SymbolIcon ArrowSync24}" Click="RefreshScan_Click" />
        </DockPanel>

        <!-- 过滤 -->
        <StackPanel Grid.Row="1" Style="{StaticResource DbkFilterBarStyle}">
            <ComboBox x:Name="cmbDatabase" Width="120" Margin="0,0,8,0" SelectionChanged="Filter_Changed"
                      MaxDropDownHeight="260" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ComboBoxItem Content="全部数据库" IsSelected="True" />
            </ComboBox>
            <ComboBox x:Name="cmbStatus" Width="100" Margin="0,0,8,0" SelectionChanged="Filter_Changed">
                <ComboBoxItem Content="全部状态" IsSelected="True" />
                <ComboBoxItem Content="正常" Tag="NORMAL" />
                <ComboBoxItem Content="异常" Tag="SIZE_ANOMALY" />
                <ComboBoxItem Content="已过期" Tag="EXPIRED" />
                <ComboBoxItem Content="已删除" Tag="DELETED" />
            </ComboBox>
            <DatePicker x:Name="dpDateFrom" Width="130" Margin="0,0,4,0" SelectedDateChanged="Filter_Changed"
                        SelectedDateFormat="Short" ToolTip="开始日期" />
            <TextBlock Text="~" VerticalAlignment="Center" Margin="0,0,4,0" />
            <DatePicker x:Name="dpDateTo" Width="130" Margin="0,0,8,0" SelectedDateChanged="Filter_Changed"
                        SelectedDateFormat="Short" ToolTip="结束日期" />
            <ui:Button x:Name="btnBatchDelete" Content="批量删除" Appearance="Danger"
                       Icon="{ui:SymbolIcon Delete24}" Click="BatchDelete_Click" IsEnabled="False" />
        </StackPanel>

        <!-- 空状态 -->
        <StackPanel x:Name="emptyState" Grid.Row="2" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Visibility="Collapsed">
            <ui:SymbolIcon Symbol="FolderOpen24" FontSize="48" HorizontalAlignment="Center" Margin="0,0,0,12"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}" />
            <TextBlock Text="暂无备份文件记录" FontSize="16" HorizontalAlignment="Center"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
        </StackPanel>

        <!-- 备份文件列表 -->
        <DataGrid x:Name="fileGrid" Grid.Row="2" Style="{StaticResource DbkDataGridStyle}"
                  SelectionMode="Single">
            <DataGrid.Columns>
                <DataGridTemplateColumn Header="选择" Width="40">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <CheckBox Click="RowCheckbox_Click" Tag="{Binding}" />
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
                <DataGridTextColumn Header="文件名" Binding="{Binding FileName}" Width="*" />
                <DataGridTextColumn Header="数据库" Binding="{Binding DatabaseName}" Width="130" />
                <DataGridTextColumn Header="大小" Binding="{Binding FileSizeBytes, Converter={StaticResource FileSize}}" Width="80" />
                <DataGridTextColumn Header="类型" Binding="{Binding BackupType}" Width="55" />
                <DataGridTextColumn Header="备份时间" Binding="{Binding CreatedAt, Converter={StaticResource IsoDateTime}}" Width="155" />
                <DataGridTextColumn Header="过期" Binding="{Binding ExpiresAt, Converter={StaticResource IsoDateTime}, ConverterParameter=yyyy-MM-dd}" Width="85" />
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="70" />
                <DataGridTemplateColumn Header="操作" Width="120">
                    <DataGridTemplateColumn.CellTemplate>
                        <DataTemplate>
                            <StackPanel Orientation="Horizontal">
                                <ui:Button ToolTip="手动保留" Margin="0,0,4,0"
                                           Icon="{ui:SymbolIcon Pin24}"
                                           Tag="{Binding}" Click="Pin_Click" />
                                <ui:Button ToolTip="打开目录" Margin="0,0,4,0"
                                           Icon="{ui:SymbolIcon FolderOpen24}"
                                           Tag="{Binding}" Click="OpenFolder_Click" />
                                <ui:Button ToolTip="删除" Appearance="Danger"
                                           Icon="{ui:SymbolIcon Delete24}"
                                           Tag="{Binding}" Click="Delete_Click" />
                            </StackPanel>
                        </DataTemplate>
                    </DataGridTemplateColumn.CellTemplate>
                </DataGridTemplateColumn>
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource DbkDataGridRowStyle}">
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>
    </Grid>
</Page>
