<Page x:Class="DBKeeper.App.Views.ExecutionLogsPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
      Title="执行日志" Loaded="Page_Loaded">

    <Grid Style="{StaticResource DbkPageGridStyle}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <DockPanel Grid.Row="0" Style="{StaticResource DbkPageTitleBarStyle}">
            <TextBlock Text="执行日志" Style="{StaticResource DbkPageTitleTextStyle}" />
            <ui:Button Content="导出 CSV" DockPanel.Dock="Right" HorizontalAlignment="Right"
                       Click="ExportCsv_Click" />
        </DockPanel>

        <!-- 过滤 -->
        <StackPanel Grid.Row="1" Style="{StaticResource DbkFilterBarStyle}">
            <ComboBox x:Name="cmbStatus" Width="100" Margin="0,0,8,0" SelectionChanged="Filter_Changed"
                      MaxDropDownHeight="260" ScrollViewer.VerticalScrollBarVisibility="Auto">
                <ComboBoxItem Content="全部状态" IsSelected="True" />
                <ComboBoxItem Content="成功" Tag="SUCCESS" />
                <ComboBoxItem Content="失败" Tag="FAILED" />
                <ComboBoxItem Content="警告" Tag="WARNING" />
            </ComboBox>
            <TextBlock Text="从" VerticalAlignment="Center" Margin="0,0,4,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <DatePicker x:Name="dpStart" Width="130" Margin="0,0,4,0" SelectedDateChanged="DateFilter_Changed" />
            <TextBlock Text="至" VerticalAlignment="Center" Margin="0,0,4,0"
                       Foreground="{DynamicResource TextFillColorSecondaryBrush}" />
            <DatePicker x:Name="dpEnd" Width="130" Margin="0,0,8,0" SelectedDateChanged="DateFilter_Changed" />
            <ui:TextBox x:Name="txtTaskFilter" PlaceholderText="搜索任务名..." Width="200"
                        TextChanged="TaskFilter_Changed" />
        </StackPanel>

        <!-- 日志表格 -->
        <DataGrid x:Name="logGrid" Grid.Row="2" Style="{StaticResource DbkDataGridStyle}"
                  SelectionMode="Single"
                  RowDetailsVisibilityMode="VisibleWhenSelected">
            <DataGrid.RowDetailsTemplate>
                <DataTemplate>
                    <Border Style="{StaticResource DbkInlineDetailsBorderStyle}">
                        <StackPanel>
                            <TextBlock Text="错误详情" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"
                                       Foreground="{DynamicResource ErrorBrush}"
                                       Visibility="{Binding ErrorDetail, Converter={StaticResource NullToCollapsed}}" />
                            <TextBox Text="{Binding ErrorDetail, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                                     BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                     FontSize="12" FontFamily="Consolas"
                                     MaxHeight="200" VerticalScrollBarVisibility="Auto"
                                     Visibility="{Binding ErrorDetail, Converter={StaticResource NullToCollapsed}}" />
                            <TextBlock Text="摘要详情" FontWeight="SemiBold" FontSize="12" Margin="0,0,0,4"
                                       Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                       Visibility="{Binding Summary, Converter={StaticResource NullToCollapsed}}" />
                            <TextBox Text="{Binding Summary, Mode=OneWay}" IsReadOnly="True" TextWrapping="Wrap"
                                     BorderThickness="0" Background="Transparent"
                                     Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                                     FontSize="12" FontFamily="Consolas"
                                     MaxHeight="150" VerticalScrollBarVisibility="Auto"
                                     Visibility="{Binding Summary, Converter={StaticResource NullToCollapsed}}" />
                        </StackPanel>
                    </Border>
                </DataTemplate>
            </DataGrid.RowDetailsTemplate>
            <DataGrid.Columns>
                <DataGridTextColumn Header="时间" Binding="{Binding StartedAt, Converter={StaticResource IsoDateTime}}" Width="155" />
                <DataGridTextColumn Header="任务名" Binding="{Binding TaskName}" Width="120" />
                <DataGridTextColumn Header="类型" Binding="{Binding TaskType}" Width="90" />
                <DataGridTextColumn Header="触发" Binding="{Binding TriggerType}" Width="70" />
                <DataGridTextColumn Header="耗时" Binding="{Binding DurationMs, StringFormat='{}{0}ms'}" Width="70" />
                <DataGridTextColumn Header="状态" Binding="{Binding Status}" Width="70" />
                <DataGridTextColumn Header="摘要" Binding="{Binding Summary}" Width="*" />
            </DataGrid.Columns>
            <DataGrid.RowStyle>
                <Style TargetType="DataGridRow" BasedOn="{StaticResource DbkDataGridRowStyle}">
                    <Setter Property="Foreground" Value="{DynamicResource TextFillColorPrimaryBrush}" />
                    <Style.Triggers>
                        <DataTrigger Binding="{Binding Status}" Value="FAILED">
                            <Setter Property="BorderBrush" Value="{DynamicResource ErrorBrush}" />
                            <Setter Property="BorderThickness" Value="3,0,0,0" />
                        </DataTrigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.RowStyle>
        </DataGrid>

        <!-- 分页 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,12,0,0">
            <ui:Button Content="上一页" Click="PrevPage_Click" Margin="0,0,8,0" />
            <TextBlock VerticalAlignment="Center" Margin="0,0,8,0"
                       Foreground="{DynamicResource TextFillColorPrimaryBrush}">
                <Run Text="{Binding CurrentPage}" />
                <Run Text=" / " />
                <Run Text="{Binding TotalPages}" />
                <Run Text=" （共 " />
                <Run Text="{Binding TotalCount}" />
                <Run Text=" 条）" />
            </TextBlock>
            <ui:Button Content="下一页" Click="NextPage_Click" />
        </StackPanel>
    </Grid>
</Page>
