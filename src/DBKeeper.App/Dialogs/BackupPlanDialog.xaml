<ui:FluentWindow x:Class="DBKeeper.App.Dialogs.BackupPlanDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
        Title="组合备份向导" Height="640" Width="520"
        MinHeight="520" MinWidth="500"
        WindowStartupLocation="CenterOwner" ResizeMode="CanResizeWithGrip"
        ExtendsContentIntoTitleBar="False">

    <Grid TextElement.Foreground="{DynamicResource TextFillColorPrimaryBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Padding="20,12,20,8" MouseLeftButtonDown="DragBar_MouseLeftButtonDown">
            <TextBlock Text="组合备份向导" FontSize="16" FontWeight="SemiBold" />
        </Border>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled"
                      CanContentScroll="False" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
            <StackPanel Margin="20,12,20,12">
                <TextBlock Text="基础信息" FontSize="14" FontWeight="SemiBold" Margin="0,0,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <TextBlock Text="策略名称" FontSize="13" Margin="0,0,0,4" />
                <ui:TextBox x:Name="txtPlanName" PlaceholderText="如：MES 数据库备份策略" Margin="0,0,0,10" />

                <TextBlock Text="绑定连接" FontSize="13" Margin="0,0,0,4" />
                <ComboBox x:Name="cmbConnection" DisplayMemberPath="Name" Margin="0,0,0,10"
                          MaxDropDownHeight="260" ScrollViewer.VerticalScrollBarVisibility="Auto" />

                <TextBlock Text="数据库名" FontSize="13" Margin="0,0,0,4" />
                <ComboBox x:Name="cmbDbName" IsEditable="True" Margin="0,0,0,10"
                          MaxDropDownHeight="260" ScrollViewer.VerticalScrollBarVisibility="Auto" />

                <TextBlock Text="备份目录" FontSize="13" Margin="0,0,0,4" />
                <DockPanel Margin="0,0,0,10">
                    <ui:Button Content="浏览" DockPanel.Dock="Right" Margin="8,0,0,0" Click="BrowseBackupDir_Click" />
                    <ui:TextBox x:Name="txtBackupDir" PlaceholderText="D:\Backup\MES" />
                </DockPanel>

                <TextBlock Text="备份计划" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <TextBlock Text="全量备份日" FontSize="13" Margin="0,0,0,4" />
                <ComboBox x:Name="cmbFullDay" Margin="0,0,0,10">
                    <ComboBoxItem Content="星期日" Tag="0" IsSelected="True" />
                    <ComboBoxItem Content="星期一" Tag="1" />
                    <ComboBoxItem Content="星期二" Tag="2" />
                    <ComboBoxItem Content="星期三" Tag="3" />
                    <ComboBoxItem Content="星期四" Tag="4" />
                    <ComboBoxItem Content="星期五" Tag="5" />
                    <ComboBoxItem Content="星期六" Tag="6" />
                </ComboBox>

                <TextBlock Text="备份时间 (HH:mm)" FontSize="13" Margin="0,0,0,4" />
                <ui:TextBox x:Name="txtBackupTime" Text="02:00" Margin="0,0,0,10" />

                <TextBlock Text="差异备份会自动安排在全量备份日以外的每天同一时间执行。"
                           FontSize="11" Margin="0,0,0,10"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap" />

                <TextBlock Text="保留策略" FontSize="14" FontWeight="SemiBold" Margin="0,8,0,8"
                           Foreground="{DynamicResource TextFillColorSecondaryBrush}" />

                <TextBlock Text="保留天数" FontSize="13" Margin="0,0,0,4" />
                <ui:TextBox x:Name="txtRetention" Text="30" Margin="0,0,0,10" />

                <TextBlock Text="最少保留份数" FontSize="13" Margin="0,0,0,4" />
                <ui:TextBox x:Name="txtMinKeep" Text="3" Margin="0,0,0,10" />

                <CheckBox x:Name="chkCleanup" Content="同时创建自动清理任务" IsChecked="True" Margin="0,0,0,10"
                          Checked="Cleanup_CheckedChanged" Unchecked="Cleanup_CheckedChanged" />

                <StackPanel x:Name="panelCleanupTime">
                    <TextBlock Text="清理时间 (HH:mm)" FontSize="13" Margin="0,0,0,4" />
                    <ui:TextBox x:Name="txtCleanupTime" Text="03:00" Margin="0,0,0,10" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,8,0,10">
                    <CheckBox x:Name="chkCompress" Content="压缩备份" IsChecked="True" Margin="0,0,16,0" />
                    <CheckBox x:Name="chkVerify" Content="完成后校验" />
                </StackPanel>

                <TextBlock Text="将创建 2 到 3 个任务：每周全量备份、其余日期差异备份，以及可选的备份清理。"
                           FontSize="11" Margin="0,0,0,10"
                           Foreground="{DynamicResource TextFillColorTertiaryBrush}"
                           TextWrapping="Wrap" />

                <TextBlock x:Name="errorText" Foreground="{DynamicResource ErrorBrush}" FontSize="12"
                           TextWrapping="Wrap" Visibility="Collapsed" />
            </StackPanel>
        </ScrollViewer>

        <Border Grid.Row="2" Style="{StaticResource DbkDialogFooterBorderStyle}">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <ui:Button Content="取消" Margin="0,0,8,0" Click="Cancel_Click" />
                <ui:Button Content="创建任务" Appearance="Primary" Click="Save_Click" />
            </StackPanel>
        </Border>
    </Grid>
</ui:FluentWindow>
