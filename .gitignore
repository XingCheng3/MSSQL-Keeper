# ========================================
# DB Keeper - .gitignore
# ========================================

# ---------- Build outputs ----------
[Bb]in/
[Oo]bj/
[Dd]ebug/
[Rr]elease/
publish/
artifacts/
x64/
x86/

# ---------- NuGet ----------
*.nupkg
*.snupkg
.nuget/
**/packages/

# ---------- Visual Studio ----------
.vs/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser
launchSettings.json

# Visual Studio cache/options
*.VisualState.xml
TestResult.xml
[Tt]est[Rr]esult*/

# ---------- JetBrains Rider ----------
.idea/
*.sln.iml

# ---------- VS Code ----------
.vscode/

# ---------- OS files ----------
Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
._*

# ---------- Runtime data ----------
logs/
data/
*.db
*.db-shm
*.db-wal

# ---------- Application config (may contain passwords) ----------
# Uncomment if you don't want to track appsettings:
# appsettings.json
# appsettings.*.json

# ---------- Publish / Deploy ----------
*.zip
*.tar.gz
*.exe
!src/**/*.ico

# ---------- Misc ----------
*.bak
*.swp
*.tmp
*~
docs/
.gemini/
